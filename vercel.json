{
  "builds": [
    {
      "src": "react_web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/pwa/(.*)", "dest": "/pwa/$1" },
    { "src": "^/(?!api/|assets/|pwa/|_next/|static/).*$", "dest": "/index.html" }
  ]
}
