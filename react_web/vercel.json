{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/pwa/(.*)", "dest": "/pwa/$1" },
    { "src": "^/(?!api/|assets/|pwa/|_next/|static/).*$", "dest": "/index.html" }
  ]
}
