<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Don't rewrite for existing files
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # Don't rewrite for existing directories
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]
    
    # Rewrite all other requests to index.html (for Flutter routing)
    RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Set DirectoryIndex - try index.html first, then index.php as fallback
DirectoryIndex index.html index.php

# Allow all requests
<IfModule mod_dir.c>
    DirectoryIndex index.html index.php
</IfModule>
