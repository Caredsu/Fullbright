<IfModule mod_rewrite.c">
    RewriteEngine On
    
    # Set DirectoryIndex for all directories
    DirectoryIndex index.html index.php
    
    # Dynamic RewriteBase - works for both local (/teacher-eval/) and production (/)
    RewriteCond %{HTTP_HOST} ^localhost [NC,OR]
    RewriteCond %{HTTP_HOST} ^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ - [E=REWRITE_BASE:/teacher-eval/]
    
    RewriteCond %{ENV:REWRITE_BASE} ^$
    RewriteRule ^(.*)$ - [E=REWRITE_BASE:/]
    
    RewriteBase %{ENV:REWRITE_BASE}

    # **CRITICAL FIX: If deployed at root but accessed with /teacher-eval/, redirect to root**
    # This removes the /teacher-eval/ prefix for requests
    RewriteCond %{REQUEST_URI} ^/teacher-eval/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^teacher-eval/(.*)$ /$1 [R=301,L]

    # Redirect favicon to pwa folder
    RewriteRule ^favicon\.png$ pwa/icons/favicon.png [NC,L]
    
    # **PRIORITY 1: API folder routes through PHP router - STOP rewriting**
    RewriteRule ^api/ - [L]
    
    # **CRITICAL: PWA folder - First check if it's a real file**
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^pwa/ - [L]
    
    # If PWA request is to a directory, serve index.html
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^pwa/?$ pwa/index.html [L]
    
    # For all other pwa/* requests without a dot (not a static file), serve index.html for Flutter routing
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^pwa/(.*)$ pwa/index.html [L]
    
    # **PRIORITY 3: Redirect asset requests to pwa folder BEFORE extension check**
    # This catches requests for /assets/, /canvaskit/, /icons/, /shaders/ and serves from pwa/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^assets/(.*)$ pwa/assets/$1 [NC,L]
    RewriteRule ^canvaskit/(.*)$ pwa/canvaskit/$1 [NC,L]
    RewriteRule ^icons/(.*)$ pwa/icons/$1 [NC,L]
    RewriteRule ^shaders/(.*)$ pwa/shaders/$1 [NC,L]

    # NEVER rewrite files with these extensions
    RewriteCond %{REQUEST_FILENAME} \.(js|css|png|jpg|jpeg|gif|svg|wasm|json|ttf|woff|woff2|ico|webp|dart|bin)$ [NC]
    RewriteRule ^(.*)$ - [L]

    # Don't rewrite if it's a real file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]
    
    # Don't rewrite if it's a real directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ - [L]

    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php?request=$1 [QSA,L]
</IfModule>
